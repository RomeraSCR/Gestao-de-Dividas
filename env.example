# ===========================================
# FINANZLIVRE - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# -------------------------------------------
# 🗄️ Banco de Dados MySQL/MariaDB
# -------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=gestao_dividas

# -------------------------------------------
# 🔐 Autenticação JWT
# -------------------------------------------
# Gere uma chave segura com: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_muito_segura_aqui

# -------------------------------------------
# 🌐 URL do Site
# -------------------------------------------
# URL pública do site (usada para OpenGraph e metadados)
NEXT_PUBLIC_SITE_URL=http://localhost:3536

# -------------------------------------------
# 🔒 HTTPS (opcional)
# -------------------------------------------
# Defina como "true" se estiver usando HTTPS
# HTTPS=true
# NEXT_PUBLIC_HTTPS=true

# -------------------------------------------
# 🛠️ Modo Mock/Sem Banco de Dados (opcional)
# -------------------------------------------
# Defina como "true" para usar um banco de dados local em arquivo JSON (database-mock.json)
# dispensando a necessidade de instalar e configurar um servidor MySQL/MariaDB localmente.
DB_MOCK=true
