# ===========================================
# FINANZLIVRE - .gitignore
# ===========================================

# -------------------------------------------
# 📦 Dependencies
# -------------------------------------------
node_modules/
.pnp/
.pnp.js

# -------------------------------------------
# 🔨 Build / Production
# -------------------------------------------
.next/
out/
build/
dist/

# -------------------------------------------
# 🧪 Testing
# -------------------------------------------
coverage/
.nyc_output/

# -------------------------------------------
# 🔐 Environment Variables
# -------------------------------------------
.env
.env.*
!env.example

# -------------------------------------------
# 📁 Uploads (Comprovantes)
# -------------------------------------------
public/comprovantes/*
!public/comprovantes/.gitkeep

# -------------------------------------------
# 🪵 Logs
# -------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# -------------------------------------------
# 💻 IDE / Editor
# -------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# -------------------------------------------
# 🖥️ OS Generated
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -------------------------------------------
# 🔧 TypeScript
# -------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -------------------------------------------
# ☁️ Deploy / Hosting
# -------------------------------------------
.vercel/
.netlify/

# -------------------------------------------
# 📦 Package managers
# -------------------------------------------
# Uncomment if you prefer to NOT commit lockfiles
# pnpm-lock.yaml
# package-lock.json
# yarn.lock

# -------------------------------------------
# 🗜️ Misc
# -------------------------------------------
*.zip
*.tar.gz
*.rar
*.7z

# -------------------------------------------
# 🧹 Cache
# -------------------------------------------
.cache/
.parcel-cache/
.turbo/
*.cache

# -------------------------------------------
# 📊 Debug
# -------------------------------------------
.fusebox/

# -------------------------------------------
# 🛠️ Mock Database
# -------------------------------------------
database-mock.json
